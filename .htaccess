# CHABOZA — Apache 설정 (CAFE24용)
# CAFE24 호스팅은 Apache + mod_rewrite + mod_headers 기본 제공

# ===== 기본 인덱스 =====
DirectoryIndex index.php index.html

# ===== HTTPS 강제 (CAFE24 무료 SSL 적용 후 켜기) =====
# RewriteEngine On
# RewriteCond %{HTTPS} !=on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ===== UTF-8 기본 charset =====
AddDefaultCharset UTF-8
AddCharset UTF-8 .html .css .js .php

# ===== 정적 자산 캐싱 (1년) =====
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css   "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
</IfModule>

# ===== gzip 압축 =====
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
</IfModule>

# ===== 민감 파일 차단 =====
<FilesMatch "^(\.htaccess|\.env|composer\.json|composer\.lock|package\.json|package-lock\.json)$">
  Require all denied
</FilesMatch>

# includes/, db/, cowork/ 디렉터리 외부 접근 차단
RewriteEngine On
RewriteRule ^(includes|db|cowork)/ - [F,L]

# ===== 보안 헤더 =====
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ===== 404 핸들러 (선택) =====
# ErrorDocument 404 /404.html

# ===== PHP 설정 (CAFE24가 허용 시) =====
<IfModule mod_php.c>
  php_value upload_max_filesize 10M
  php_value post_max_size 10M
  php_value default_charset UTF-8
</IfModule>
